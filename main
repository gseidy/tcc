      - name: "Rastreador Slot 01 X Trilateracao"
        unique_id: rastreador_slot_01_x_trilateracao
        unit_of_measurement: "m"
        state_class: measurement
        state: >
          {% set id = states('input_text.slot_01_id') %}
          {% if id in ['unknown', '', 'unavailable'] %} 0 {% else %}
            {% set base = 'sensor.bermuda_' ~ id ~ '_distance_to_proxy_bermuda_' %}
            {% set d1 = states(base~'01')|float(10) %}
            {% set d2 = states(base~'02')|float(10) %}
            {% set d3 = states(base~'03')|float(10) %}
            {% set x1, y1, x2, y2, x3, y3 = 0.0, 2.23, 2.35, 0.77, 0.2, 0.0 %}
            {% set A, B = 2*(x2-x1), 2*(y2-y1) %}
            {% set C = d1**2 - d2**2 - x1**2 + x2**2 - y1**2 + y2**2 %}
            {% set D, E = 2*(x3-x2), 2*(y3-y2) %}
            {% set F = d2**2 - d3**2 - x2**2 + x3**2 - y2**2 + y3**2 %}
            {% set div = (E*A - B*D) %}
            {{ ((C*E - F*B) / div) | round(2) if div != 0 else 0 }}
          {% endif %}

      - name: "Rastreador Slot 01 Y Trilateracao"
        unique_id: rastreador_slot_01_y_trilateracao
        unit_of_measurement: "m"
