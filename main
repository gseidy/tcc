  - sensor:
      # --- SLOT 01 X (WCL) ---
      - name: "Rastreador Slot 01 X"
        unique_id: rastreador_slot_01_x
        unit_of_measurement: "m"      # <--- Corrige gráfico de barra para linha
        state_class: measurement
        state: >
          {% set id = states('input_text.slot_01_id') %}
          {% if id in ['unknown', '', 'unavailable'] %} 0 {% else %}
            {% set base = 'sensor.bermuda_' ~ id ~ '_distance_to_proxy_bermuda_' %}
            {% set d1 = states(base~'01')|float(10) %}
            {% set d2 = states(base~'02')|float(10) %}
            {% set d3 = states(base~'03')|float(10) %}
            {% set x1, x2, x3 = 0.00, 2.35, 0.20 %}
            {% set g = 2.2 %}
            {% set w1 = 1 / (([0.3, d1]|max) ** g) %}
            {% set w2 = 1 / (([0.3, d2]|max) ** g) %}
            {% set w3 = 1 / (([0.3, d3]|max) ** g) %}
            {{ ((x1*w1 + x2*w2 + x3*w3) / (w1+w2+w3)) | round(2) }}
          {% endif %}

      # --- SLOT 01 Y (WCL) ---
      - name: "Rastreador Slot 01 Y"
        unique_id: rastreador_slot_01_y
        unit_of_measurement: "m"
